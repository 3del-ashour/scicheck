# --- LLM provider ---
# Pick ONE of the three configurations below.

# Option A — OpenAI (paid, default)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=    # leave empty for OpenAI

# Option B — Groq (free tier, no credit card; very fast)
# Sign up at https://console.groq.com → API Keys → Create API Key
# OPENAI_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Option C — Ollama (100% local, free, no signup)
# Install: https://ollama.com  →  ollama pull llama3.1:8b
# OPENAI_API_KEY=ollama   # any non-empty value works
# LLM_MODEL=llama3.1:8b
# LLM_BASE_URL=http://localhost:11434/v1

# --- Vector store + embeddings (free, local) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PATH=./data/chroma
TOP_K=5
LOG_LEVEL=INFO
